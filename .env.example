# Server
PORT=3000

# Event
EVENT_NAME=Saadhyam AI Event
CERTIFICATE_DELAY_HOURS=48

# Firebase Web SDK (client — configured)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id

# Firebase Admin (optional — for server-side certificate generation)
# Download from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json
FIREBASE_COLLECTION=registrations

# Community link (shown on virtual ID card + overlay)
COMMUNITY_LINK=https://chat.whatsapp.com/your-invite-code

# Cloudinary (recommended for photo storage — no CORS issues)
# Sign up free at https://cloudinary.com · get credentials from Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=saadhyam-ai/registrations
